# Copy to /etc/client-secret-vault/server.env and adapt values.

APP_BASE_DIR=/srv/secret-vault
RELEASES_DIR=/srv/secret-vault/releases
CURRENT_LINK=/srv/secret-vault/app

DEPLOY_PROFILE=prod
RUN_MIGRATIONS=true
APP_SERVICE_NAME=app
COMPOSE_PROJECT_NAME=secret-vault
SHARED_EDGE_NETWORK=saas-edge

APP_ENV=prod
APP_DEBUG=0
SERVER_NAME=secret-vault.dsn-dev.com
BASE_URI=https://secret-vault.dsn-dev.com
APP_HTTP_PORT=8090
HEALTHCHECK_URL=http://127.0.0.1:8090/healthz
HEALTHCHECK_ATTEMPTS=8
HEALTHCHECK_SLEEP_SECONDS=5

DEFAULT_URI=${BASE_URI}
APP_SECRET=change-me
APP_2FA_ISSUER='Client Secrets Vault'
SYMFONY_TRUSTED_PROXIES=private_ranges
VAULT_ENCRYPTION_KEY=replace-with-64-hex-chars
VAULT_KMS_PROVIDER=transit
VAULT_ACTIVE_KEY_ID=legacy-local-key
VAULT_KMS_KEYRING=legacy-local-key:replace-with-64-hex-chars
VAULT_TRANSIT_ADDR=https://vault.internal:8200
VAULT_TRANSIT_TOKEN=replace-with-vault-token
VAULT_TRANSIT_NAMESPACE=
VAULT_TRANSIT_KEY_NAME=client-secret-vault
SECURITY_ALERT_RECIPIENTS=security@example.com
POSTGRES_PORT=5452
POSTGRES_DB=client_secret_vault
POSTGRES_USER=app
POSTGRES_PASSWORD=replace-with-db-password
DATABASE_URL=postgresql://app:replace-with-db-password@database:5432/client_secret_vault?serverVersion=16&charset=utf8
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
MAILER_DSN=null://null
