# Copy to /etc/client-secret-vault/server.env and adapt values.

APP_BASE_DIR=/srv/client-secret-vault
RELEASES_DIR=/srv/client-secret-vault/releases
CURRENT_LINK=/srv/client-secret-vault/current

DEPLOY_PROFILE=prod
RUN_MIGRATIONS=true
APP_SERVICE_NAME=app

APP_PUBLIC_DOMAIN=secret-vault.dsn-dev.com
APP_HTTP_PORT=8090
POSTGRES_PORT=5452
HEALTHCHECK_URL=http://127.0.0.1:8090/healthz
HEALTHCHECK_ATTEMPTS=8
HEALTHCHECK_SLEEP_SECONDS=5

DEFAULT_URI=https://secret-vault.dsn-dev.com
APP_SECRET=change-me
APP_2FA_ISSUER=Client Secrets Vault
VAULT_ENCRYPTION_KEY=replace-with-64-hex-chars
CHILD_APP_PROVISIONING_TOKEN=replace-with-provisioning-token

POSTGRES_DB=client_secret_vault
POSTGRES_USER=client_secret_vault
POSTGRES_PASSWORD=replace-with-db-password
