{% extends 'security/auth_base.html.twig' %}

{% block title %}Connexion | Client Secrets Vault{% endblock %}

{% block body %}
    <span class="brand__eyebrow">Accès sécurisé</span>
    <h1>Déverrouiller le coffre</h1>
    <p>Connexion par mot de passe, puis validation par application d’authentification TOTP.</p>

    {% if error %}
        <div class="flash flash--error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <form method="post" class="stack">
        <div class="field">
            <label for="username">Email</label>
            <input type="email" id="username" name="_username" value="{{ last_username }}" autocomplete="email" required autofocus>
        </div>
        <div class="field">
            <label for="password">Mot de passe</label>
            <input type="password" id="password" name="_password" autocomplete="current-password" required>
        </div>
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        <button type="submit">Entrer dans le vault</button>
    </form>
{% endblock %}
