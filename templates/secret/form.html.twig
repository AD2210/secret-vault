{% extends 'base.html.twig' %}

{% block title %}{{ title }} | Client Secrets Vault{% endblock %}
{% block page_title %}{{ title }}{% endblock %}
{% block page_intro %}{{ secretDefinition.description }}{% endblock %}

{% block body %}
    <section class="panel">
        <div class="actions" style="margin-bottom: 16px;">
            <span class="badge">{{ secretDefinition.label }}</span>
            {% if secretDefinition.generator %}
                <a class="button button--ghost" href="{{ path('app_generator_index') }}">Ouvrir le générateur</a>
            {% endif %}
            {% if project %}
                <a class="button button--ghost" href="{{ path('app_secret_new', {id: project.idString}) }}">Changer de type</a>
            {% endif %}
        </div>

        {{ form_start(form, {attr: {class: 'stack'}}) }}
            <div class="form-grid">
                <div class="field">{{ form_label(form.name) }}{{ form_widget(form.name) }}{{ form_errors(form.name) }}</div>
                {% for field in secretDefinition.fields %}
                    <div class="{{ field.input == 'textarea' ? 'field-wide' : 'field' }}">
                        {{ form_label(attribute(form, field.key)) }}
                        {{ form_widget(attribute(form, field.key)) }}
                        {{ form_help(attribute(form, field.key)) }}
                        {{ form_errors(attribute(form, field.key)) }}
                    </div>
                {% endfor %}
            </div>
            <div class="actions">
                <button type="submit">Enregistrer</button>
                {% if project %}
                    <a class="button button--ghost" href="{{ path('app_project_show', {id: project.idString}) }}">Retour au projet</a>
                {% endif %}
            </div>
        {{ form_end(form) }}
    </section>
{% endblock %}
