{% extends 'base.html.twig' %}

{% block title %}{{ title }} | Client Secrets Vault{% endblock %}
{% block page_title %}{{ title }}{% endblock %}
{% block page_intro %}Projet cible: {{ project ? project.name : 'n/a' }}{% endblock %}

{% block body %}
    <section class="panel">
        {{ form_start(form, {attr: {class: 'stack'}}) }}
            <div class="form-grid">
                <div class="field-wide">{{ form_label(form.name) }}{{ form_widget(form.name) }}{{ form_errors(form.name) }}</div>
                <div class="field-wide">{{ form_label(form.publicSecret) }}{{ form_widget(form.publicSecret) }}{{ form_errors(form.publicSecret) }}</div>
                <div class="field-wide">{{ form_label(form.privateSecret) }}{{ form_widget(form.privateSecret) }}{{ form_errors(form.privateSecret) }}</div>
            </div>
            <div class="actions">
                <button type="submit">Enregistrer</button>
                {% if project %}
                    <a class="button button--ghost" href="{{ path('app_project_show', {id: project.idString}) }}">Retour au projet</a>
                {% endif %}
            </div>
        {{ form_end(form) }}
    </section>
{% endblock %}
