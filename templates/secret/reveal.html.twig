{% extends 'base.html.twig' %}

{% block title %}Révéler {{ secret.name }} | Client Secrets Vault{% endblock %}
{% block page_title %}Révéler un secret{% endblock %}
{% block page_intro %}Validation TOTP requise pour ouvrir une fenêtre de consultation courte.{% endblock %}

{% block body %}
    <section class="panel">
        <div class="stack">
            <div>
                <div class="badge">Accès sensible</div>
                <h3 style="margin-bottom: 8px;">{{ secret.name }}</h3>
                <p class="help">Le secret sera visible pendant {{ ttlSeconds }} secondes sur la fiche projet après validation.</p>
            </div>

            {{ form_start(form, {attr: {class: 'stack'}}) }}
                <div class="field">{{ form_label(form.code) }}{{ form_widget(form.code) }}{{ form_errors(form.code) }}</div>
                <div class="actions">
                    <button type="submit">Valider et révéler</button>
                    <a class="button button--ghost" href="{{ path('app_project_show', {id: secret.project.idString}) }}">Retour au projet</a>
                </div>
            {{ form_end(form) }}
        </div>
    </section>
{% endblock %}
