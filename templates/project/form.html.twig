{% extends 'base.html.twig' %}

{% block title %}{{ title }} | Client Secrets Vault{% endblock %}
{% block page_title %}{{ title }}{% endblock %}
{% block page_intro %}Le projet ne stocke ici que son cadre métier et les affectations d’équipe.{% endblock %}

{% block body %}
    <section class="panel">
        {{ form_start(form, {attr: {class: 'stack'}}) }}
            <div class="form-grid">
                <div class="field">{{ form_label(form.name) }}{{ form_widget(form.name) }}{{ form_errors(form.name) }}</div>
                <div class="field">{{ form_label(form.client) }}{{ form_widget(form.client) }}{{ form_errors(form.client) }}</div>
            </div>
            <div class="actions">
                <button type="submit">Enregistrer</button>
                <a class="button button--ghost" href="{{ path('app_project_index') }}">Retour</a>
            </div>
        {{ form_end(form) }}
    </section>

    {% if app.request.attributes.get('_route') == 'app_project_edit' %}
        <section class="panel">
            <h3>Danger zone</h3>
            <form method="post" action="{{ path('app_project_delete', {id: project.idString}) }}" onsubmit="return confirm('Supprimer définitivement ce projet ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete-project-' ~ project.idString) }}">
                <button class="button button--ghost" type="submit">Supprimer ce projet</button>
            </form>
        </section>
    {% endif %}

{% endblock %}
