{% extends 'base.html.twig' %}

{% block title %}Projets | Client Secrets Vault{% endblock %}
{% block page_title %}Projets{% endblock %}
{% block page_intro %}Chaque projet centralise ses secrets typés et les personnes autorisées à y accéder.{% endblock %}
{% block header_actions %}
    {% if app.user and app.user.canCreateProjects %}
        <a class="button" href="{{ path('app_project_new') }}">Créer un projet</a>
    {% endif %}
{% endblock %}

{% block body %}
    <section class="panel">
        {% if projects is empty %}
            <div class="empty-state">Aucun projet disponible.</div>
        {% else %}
            <table class="table">
                <thead>
                    <tr>
                        <th>Projet</th>
                        <th>Client</th>
                        <th>Lead</th>
                        <th>Membres</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for project in projects %}
                        <tr>
                            <td>{{ project.name }}</td>
                            <td>{{ project.client }}</td>
                            <td>{{ project.createdBy.displayName }}</td>
                            <td>{{ project.members|length }}</td>
                            <td class="inline-actions">
                                <a class="button button--ghost" href="{{ path('app_project_show', {id: project.idString}) }}">Voir</a>
                                {% if is_granted('PROJECT_EDIT', project) %}
                                    <a class="button button--ghost" href="{{ path('app_project_edit', {id: project.idString}) }}">Modifier</a>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </section>
{% endblock %}
