{% extends 'base.html.twig' %}

{% block title %}{{ project.name }} | Client Secrets Vault{% endblock %}
{% block page_title %}{{ project.name }}{% endblock %}
{% block page_intro %}{{ project.client }}{% endblock %}
{% block header_actions %}
    {% if app.user and app.user.canCreateSecrets %}
        <a class="button" href="{{ path('app_secret_new', {id: project.idString}) }}">Ajouter un secret</a>
    {% endif %}
    {% if is_granted('PROJECT_EDIT', project) %}
        <a class="button button--ghost" href="{{ path('app_project_edit', {id: project.idString}) }}">Modifier</a>
    {% endif %}
{% endblock %}

{% block body %}
    <div class="stack">
        <section class="panel">
            <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));">
                <div>
                    <div class="badge">Projet</div>
                    <p><strong>Nom:</strong> {{ project.name }}</p>
                    <p><strong>Client:</strong> {{ project.client }}</p>
                </div>
                <div>
                    <div class="badge">Collaboration</div>
                    <p><strong>Lead:</strong> {{ project.createdBy.displayName }}</p>
                    <p><strong>Membres:</strong>
                        {% for member in project.members %}
                            {{ member.displayName }} ({{ member.roleLabel }}){% if not loop.last %}, {% endif %}
                        {% else %}
                            aucun
                        {% endfor %}
                    </p>
                </div>
            </div>
        </section>

        {% if membersForm %}
            <section class="panel">
                <div class="content__header" style="margin-bottom: 16px;">
                    <div>
                        <h3 style="margin: 0;">Affectation des membres</h3>
                        <p>Gère ici les utilisateurs rattachés à ce projet.</p>
                    </div>
                </div>
                {{ form_start(membersForm, {action: path('app_project_members_update', {id: project.idString}), attr: {class: 'stack'}}) }}
                    <div class="field-wide">{{ form_label(membersForm.members) }}{{ form_widget(membersForm.members) }}{{ form_errors(membersForm.members) }}</div>
                    <div class="actions">
                        <button type="submit">Mettre à jour</button>
                    </div>
                {{ form_end(membersForm) }}
            </section>
        {% endif %}

        <section class="panel">
            <div class="content__header" style="margin-bottom: 16px;">
                <div>
                    <h3 style="margin: 0;">Secrets du projet</h3>
                    <p>Chaque secret est stocké selon son type métier.</p>
                </div>
            </div>

            {% if project.secrets is empty %}
                <div class="empty-state">Aucun secret pour ce projet.</div>
            {% else %}
                <div class="list">
                    {% for secret in project.secrets %}
                        {% set definition = secretTypes[secret.type] ?? secretTypes['other'] %}
                        {% set isRevealed = revealedSecrets[secret.idString] ?? false %}
                        {% set payload = secretPayloads[secret.idString] ?? {} %}
                        <div
                            data-controller="modal{% if isRevealed %} secret-visibility{% endif %}"
                            data-modal-open-class="is-open"
                            data-modal-open="{{ openRevealSecretId == secret.idString ? 'true' : 'false' }}"
                            {% if isRevealed %}
                                data-secret-visibility-expires-at-value="{{ revealExpirations[secret.idString]|date('c') }}"
                                data-secret-visibility-reveal-label-value="Révéler 60s"
                            {% endif %}
                        >
                            <div class="list-item">
                                <div class="actions" style="justify-content: space-between; align-items: flex-start; gap: 24px;">
                                    <div>
                                        <strong>{{ secret.name }}</strong>
                                        <div class="badge" style="margin: 12px 0;">{{ definition.label }}</div>
                                        <div class="help">Créé par {{ secret.createdBy ? secret.createdBy.displayName : 'n/a' }}</div>
                                        {% if isRevealed %}
                                            <div class="security-note" data-secret-visibility-target="note">Visible jusqu’à {{ revealExpirations[secret.idString]|date('H:i:s') }}</div>
                                        {% else %}
                                            <div class="security-note">Masqué par défaut. Une validation TOTP ouvre une fenêtre de consultation courte.</div>
                                        {% endif %}
                                        <div class="grid" style="margin-top: 16px; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));">
                                            {% for field in definition.fields %}
                                                {% set fieldValue = isRevealed ? (attribute(payload, field.key) ?: '') : '' %}
                                                {% set singleLine = fieldValue and "\n" not in fieldValue and "\r" not in fieldValue %}
                                                <div>
                                                    <div class="help">{{ field.label }}</div>
                                                    <div class="generator-result__card" data-controller="copy-value"{% if isRevealed %} data-copy-value-log-url-value="{{ path('app_secret_copy_log', {id: secret.idString}) }}"{% endif %}>
                                                        <div class="generator-result__value{{ singleLine ? ' generator-result__value--single-line' : '' }}">
                                                            <div class="secret-box{{ isRevealed ? '' : ' secret-box--masked' }}" data-copy-value-target="source"{% if isRevealed %} data-secret-visibility-target="source"{% endif %}>{{ isRevealed ? (fieldValue ?: 'Aucune valeur') : '••••••••••' }}</div>
                                                            {% if isRevealed and fieldValue %}
                                                                <button type="button" class="generator-result__copy" title="Copier" aria-label="Copier" data-copy-value-target="button" data-secret-visibility-target="copyButton" data-action="click->copy-value#copy">
                                                                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                                                        <rect x="9" y="9" width="10" height="10" rx="2" stroke="currentColor" stroke-width="1.7"/>
                                                                        <path d="M6 15H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v1" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                                                                    </svg>
                                                                    <span class="sr-only">Copier</span>
                                                                </button>
                                                            {% endif %}
                                                        </div>
                                                    </div>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                    <div class="actions">
                                        <a
                                            class="button button--ghost"
                                            href="{{ path('app_project_show', {id: project.idString, reveal: secret.idString}) }}"
                                            data-action="click->modal#open"
                                            {% if isRevealed %}data-secret-visibility-target="trigger"{% endif %}
                                        >{{ isRevealed ? 'Prolonger' : 'Révéler 60s' }}</a>
                                        {% if is_granted('SECRET_EDIT', secret) %}
                                            <a class="button button--ghost" href="{{ path('app_secret_edit', {id: secret.idString}) }}">Modifier</a>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <div
                                class="modal{% if openRevealSecretId == secret.idString %} is-open{% endif %}"
                                data-modal-target="overlay"
                                data-action="click->modal#closeOnBackdrop keydown@window->modal#closeOnEscape"
                            >
                                <div class="modal__panel" data-modal-target="panel" role="dialog" aria-modal="true" aria-labelledby="reveal-title-{{ secret.idString }}">
                                    <div class="modal__head">
                                        <div>
                                            <div class="badge">Accès sensible</div>
                                            <h3 id="reveal-title-{{ secret.idString }}">{{ secret.name }}</h3>
                                            <p class="help">Validation TOTP requise pour ouvrir une fenêtre de consultation courte.</p>
                                        </div>
                                        <a class="modal__close" href="{{ path('app_project_show', {id: project.idString}) }}" aria-label="Fermer" data-action="click->modal#close">×</a>
                                    </div>
                                    {{ form_start(revealForms[secret.idString], {attr: {class: 'stack'}}) }}
                                        <div class="field">
                                            {{ form_label(revealForms[secret.idString].code) }}
                                            {{ form_widget(revealForms[secret.idString].code) }}
                                            {{ form_errors(revealForms[secret.idString].code) }}
                                        </div>
                                        <div class="actions">
                                            <button type="submit">Valider et révéler</button>
                                            <a class="button button--ghost" href="{{ path('app_project_show', {id: project.idString}) }}" data-action="click->modal#close">Annuler</a>
                                        </div>
                                    {{ form_end(revealForms[secret.idString]) }}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </section>
    </div>
{% endblock %}
