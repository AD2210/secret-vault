{% extends 'base.html.twig' %}

{% block title %}Équipe | Client Secrets Vault{% endblock %}
{% block page_title %}Équipe{% endblock %}
{% block page_intro %}Gestion des comptes internes pouvant accéder au coffre-fort client.{% endblock %}
{% block header_actions %}
    <a class="button" href="{{ path('app_team_new') }}">Inviter un utilisateur</a>
{% endblock %}

{% block body %}
    <section class="panel">
        {% if users is empty %}
            <div class="empty-state">Aucun utilisateur.</div>
        {% else %}
            <table class="table">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>Email</th>
                        <th>Rôle</th>
                        <th>2FA</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                        <tr>
                            <td>{{ user.displayName }}</td>
                            <td>{{ user.email }}</td>
                            <td>{{ user.admin ? 'Admin' : 'Membre' }}</td>
                            <td>{{ user.totpAuthenticationEnabled ? 'Actif' : 'À activer' }}</td>
                            <td>{{ user.active ? 'Actif' : 'Désactivé' }}</td>
                            <td><a class="button button--ghost" href="{{ path('app_team_edit', {id: user.idString}) }}">Modifier</a></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </section>
{% endblock %}
