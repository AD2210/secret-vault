{% extends 'base.html.twig' %}

{% block title %}Tableau de bord | Client Secrets Vault{% endblock %}
{% block page_title %}Tableau de bord{% endblock %}
{% block page_intro %}Pilotage des projets affectés, de l’équipe et des secrets typés du vault.{% endblock %}
{% block header_actions %}
    {% if currentUser.canCreateProjects %}
        <a class="button" href="{{ path('app_project_new') }}">Nouveau projet</a>
    {% endif %}
{% endblock %}

{% block body %}
    <div class="stack">
        <section class="panel panel--hero">
            <div class="grid grid--cards">
                <div class="metric">
                    <span>Utilisateur</span>
                    <strong>{{ currentUser.displayName }}</strong>
                </div>
                <div class="metric">
                    <span>Projets accessibles</span>
                    <strong>{{ projectCount }}</strong>
                </div>
                <div class="metric">
                    <span>Secrets stockés</span>
                    <strong>{{ secretCount }}</strong>
                </div>
                <div class="metric">
                    <span>Rôle</span>
                    <strong>{{ currentUser.roleLabel }}</strong>
                </div>
            </div>
        </section>

        <section class="panel">
            <div class="content__header" style="margin-bottom: 16px;">
                <div>
                    <h3 style="margin: 0;">Derniers projets</h3>
                    <p>Tu retrouves ici les projets où tu peux consulter ou gérer les secrets selon ton rôle.</p>
                </div>
            </div>

            {% if projects is empty %}
                <div class="empty-state">Aucun projet enregistré pour l’instant.</div>
            {% else %}
                <div class="list">
                    {% for project in projects|slice(0, 5) %}
                        <div class="list-item">
                            <div class="actions" style="justify-content: space-between;">
                                <div>
                                    <strong>{{ project.name }}</strong>
                                    <div class="muted">{{ project.client }}</div>
                                </div>
                                <a class="button button--ghost" href="{{ path('app_project_show', {id: project.idString}) }}">Ouvrir</a>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </section>

        <section class="panel">
            <div class="content__header" style="margin-bottom: 16px;">
                <div>
                    <h3 style="margin: 0;">Outils</h3>
                    <p>Prépare des mots de passe, clés SSH et clés hexadécimales à injecter dans tes secrets.</p>
                </div>
            </div>
            <div class="actions">
                <a class="button button--ghost" href="{{ path('app_generator_index') }}">Ouvrir les générateurs</a>
            </div>
        </section>
    </div>
{% endblock %}
